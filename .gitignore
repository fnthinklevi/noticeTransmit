.gitignore
# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
update.md
base.md
crash_log.txt
flutter_complete_tutorial.md
server/node_modules/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Signing keys
*.jks
*.keystore
android/key.jks
android/app/key.jks
android/key.properties

# Environment variables
.env
.env.local
.env.*.local

# Server runtime data
server/data/blocked_ips.json
server/data/failed_attempts.json
server/data/version.json
server/data/hotfix.json
server/data/totp_config.json

# Gradle build artifacts
install_dir/
.workbuddy/