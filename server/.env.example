# 通知推送助手 - 服务端环境变量模板
# 复制本文件为 .env 并在部署机上填写真实值。
# 注意：.env 已被 .gitignore 忽略，切勿将含真实密钥的 .env 提交到仓库。

# 服务监听端口
PORT=3456

# 管理员登录 Token 的 bcrypt 哈希（非明文密码）。
# 生成方式（需先 npm install）：
#   node -e "console.log(require('bcryptjs').hashSync('你的管理员密码', 10))"
ADMIN_TOKEN_HASH=__REPLACE_WITH_BCRYPT_HASH__

# TOTP secret 的 AES-256-GCM 加密密钥，必须 64 位十六进制（32 字节）。
# 生成方式：
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=__REPLACE_WITH_64_HEX_CHARS__

# 运行环境
NODE_ENV=production
